{
    "name": "greenleafadvancement/clean-yaml",
    "type": "library",
    "description": "Dump diff-friendly, readable YAML (Symfony 5+ compatible fork)",
    "license": "MIT",
    "authors": [
        {
            "name": "PJ Eby",
            "homepage": "https://github.com/pjeby"
        },
        {
            "name": "Greenleaf Advancement",
            "homepage": "https://greenleafadvancement.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/yaml": "^5.4 || ^6.0 || ^7.0"
    },
    "keywords": [
        "yaml"
    ],
    "autoload": {
        "psr-4": {
            "dirtsimple\\": "src"
        }
    },
    "require-dev": {
        "peridot-php/leo": "~1.6",
        "peridot-php/peridot": "~1.19",
        "peridot-php/peridot-watcher-plugin": "^1.3"
    },
    "config": {
        "process-timeout": 0
    },
    "scripts": {
        "watch": "peridot --force-colors --watch specs",
        "test": "peridot specs"
    }
}
